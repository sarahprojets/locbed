# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Developers > API keys / Webhooks (test mode to start)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Mapbox — account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google/Apple/Facebook OAuth client IDs & secrets are NOT set here — they
# are configured directly in the Supabase Dashboard under
# Authentication > Providers.
